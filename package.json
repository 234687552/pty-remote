{
  "name": "pty-remote-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:relay": "npm run build --workspace @lzdi/pty-remote-relay",
    "build:cli": "npm run build --workspace @lzdi/pty-remote-cli",
    "dev": "concurrently -k \"npm:dev:relay\" \"npm:dev:cli\"",
    "dev:relay": "npm run dev --workspace @lzdi/pty-remote-relay",
    "dev:cli": "npm run dev --workspace @lzdi/pty-remote-cli",
    "dev:cli:claude": "npm run dev:claude --workspace @lzdi/pty-remote-cli",
    "dev:cli:codex": "npm run dev:codex --workspace @lzdi/pty-remote-cli",
    "start:relay": "npm run start --workspace @lzdi/pty-remote-relay",
    "start:cli": "npm run start --workspace @lzdi/pty-remote-cli",
    "start:cli:claude": "npm run start:claude --workspace @lzdi/pty-remote-cli",
    "start:cli:codex": "npm run start:codex --workspace @lzdi/pty-remote-cli",
    "release:publish": "node scripts/publish-workspaces.mjs",
    "threads": "npm run threads --workspace @lzdi/pty-remote-cli"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
